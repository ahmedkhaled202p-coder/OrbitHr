# Orbit HR production environment - domain neutral
# بعد اختيار الدومين الجديد ضع الرابط هنا، مثال:
# ORBIT_HR_PUBLIC_ORIGIN=https://your-domain.com
# ORBIT_HR_ALLOWED_ORIGINS=https://your-domain.com
# تركهما فارغين مناسب عند تشغيل الواجهة والـ API على نفس الدومين.
ORBIT_HR_PUBLIC_ORIGIN=
ORBIT_HR_ALLOWED_ORIGINS=
ORBIT_HR_HOST=127.0.0.1
ORBIT_HR_PORT=8080
ORBIT_HR_TIMEZONE=Africa/Cairo
ORBIT_HR_MAX_UPLOAD_BYTES=15728640

# Bootstrap accounts on a fresh database.
# This password is used for admin@hr.local, manager@hr.local and employee@hr.local on first run.
ORBIT_HR_DEFAULT_BOOTSTRAP_PASSWORD="ahmed01021676402##"
ORBIT_HR_BOOTSTRAP_ADMIN_PASSWORD="ahmed01021676402##"
ORBIT_HR_BOOTSTRAP_MANAGER_PASSWORD="ahmed01021676402##"
ORBIT_HR_BOOTSTRAP_EMPLOYEE_PASSWORD="ahmed01021676402##"

# Keep false after first run. Set true only once if you intentionally want to reset the 3 bootstrap accounts.
ORBIT_HR_FORCE_PASSWORD_CHANGE=false
ORBIT_HR_RESET_BOOTSTRAP_PASSWORDS_ON_START=false
