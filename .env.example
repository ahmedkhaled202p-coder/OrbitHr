# Orbit HR production environment template
# انسخ هذا الملف إلى .env ثم عدّل الدومين وكلمات المرور.
ORBIT_HR_PUBLIC_ORIGIN=https://YOUR_DOMAIN_HERE
ORBIT_HR_ALLOWED_ORIGINS=https://YOUR_DOMAIN_HERE
ORBIT_HR_HOST=127.0.0.1
ORBIT_HR_PORT=8080
ORBIT_HR_TIMEZONE=Africa/Cairo
ORBIT_HR_MAX_UPLOAD_BYTES=15728640

ORBIT_HR_DEFAULT_BOOTSTRAP_PASSWORD="CHANGE_THIS_STRONG_PASSWORD"
ORBIT_HR_BOOTSTRAP_ADMIN_PASSWORD="CHANGE_THIS_STRONG_PASSWORD"
ORBIT_HR_BOOTSTRAP_MANAGER_PASSWORD="CHANGE_THIS_STRONG_PASSWORD"
ORBIT_HR_BOOTSTRAP_EMPLOYEE_PASSWORD="CHANGE_THIS_STRONG_PASSWORD"

ORBIT_HR_FORCE_PASSWORD_CHANGE=false
ORBIT_HR_RESET_BOOTSTRAP_PASSWORDS_ON_START=false
